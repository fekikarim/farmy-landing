# Farmy Landing Page - Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git - it's already in .gitignore

# ============================================
# REQUIRED: API Configuration
# ============================================
# Backend API URL (include protocol and /api/v1 path)

# Production backend (currently deployed)
VITE_API_URL=https://farmy.giize.com/api/v1

# Local development backend
# VITE_API_URL=http://localhost:3000/api/v1

# ============================================
# OPTIONAL: Analytics & Monitoring
# ============================================
# VITE_ENABLE_ANALYTICS=true
# VITE_ANALYTICS_ID=your-analytics-id

# ============================================
# Build Configuration (handled by CI/CD)
# ============================================
# NODE_ENV is set automatically by npm scripts
# Vite handles import.meta.env.PROD/DEV automatically
